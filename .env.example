# ==========================================
# 1. DATABASE CONFIGURATION
# ==========================================
# Jika pakai DOCKER, gunakan konfigurasi ini:
DB_USER=user
DB_PASSWORD=password
DB_NAME=ai-tehyung
DATABASE_URL=postgresql://user:password@db:5432/ai-tehyung

# Jika pakai LOCAL TANPA DOCKER, gunakan konfigurasi ini (komen baris atas, dan aktifkan baris bawah):
# DATABASE_URL=postgresql://user:password@localhost:5432/ai-tehyung

# ==========================================
# 2. NEXT-AUTH CONFIGURATION
# ==========================================
AUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32
# Ganti dengan IP server/komputer kamu jika diakses dari luar
AUTH_URL=http://localhost:3000

# ==========================================
# 3. AI (Phase 2)
# ==========================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.6-flash-lite

# ==========================================
# 4. SEED USER (untuk scripts/seed.ts)
# ==========================================
SEED_USER_EMAIL=umam@ai-tehyung.local
SEED_USER_PASSWORD=changeme123
SEED_USER_NAME=Khoerul Umam
